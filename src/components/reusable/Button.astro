---
const { class: className, buttonText, link, arrow, inverted = false } = Astro.props as Props;
import { Icon } from "astro-icon/components";
import { twMerge } from "tailwind-merge";

export type Props = {
    buttonText: string;
    link: string;
    class?: string;
    arrow?: boolean;
    inverted?: boolean;
};

const baseClasses = "group relative overflow-hidden px-8 py-3 rounded-full text-base font-medium transition-all duration-300 ease-in-out";

const defaultClasses = "border-black border text-black hover:text-white";
const invertedClasses = "border-white border text-white hover:text-black bg-black hover:border-black";

const backgroundDefaultClasses = "bg-black group-hover:h-full";
const backgroundInvertedClasses = "bg-white group-hover:h-full";

const textDefaultClasses = "text-gray-600 group-hover:text-white";
const textInvertedClasses = "text-white group-hover:text-black";

const typeClasses = inverted ? invertedClasses : defaultClasses;
const backgroundClasses = inverted ? backgroundInvertedClasses : backgroundDefaultClasses;
const textClasses = inverted ? textInvertedClasses : textDefaultClasses;

const combinedClasses = twMerge(baseClasses, typeClasses, className);
---

<a href={link} class={combinedClasses}>
    <span class="relative z-10 inline-flex items-center justify-center text-center">
        {buttonText}
        {arrow && <Icon name="arrow-down" class={twMerge("ml-2 -mr-1 w-5 -rotate-90 h-5 transition-colors duration-300", textClasses)} />}
    </span>
    <span class={twMerge("absolute inset-x-0 bottom-0 z-0 h-0 w-full rounded-full transition-all duration-300 ease-in-out", backgroundClasses)} />
</a>