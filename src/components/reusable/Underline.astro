---

const text = await Astro.slots.render('default')
// A simple hashing function to convert text into a seed
const stringToSeed = (str: string) => {
  let hash = 0;
  if (str.length === 0) return 0;
  for (let i = 0; i < str.length; i++) {
    const char = str.charCodeAt(i);
    hash = (hash << 5) - hash + char;
    hash |= 0; // Ensure it's a 32-bit integer
  }
  return Math.abs(hash);
};

// A very simple pseudo-random number generator (PRNG)
const mulberry32 = (seed: number) => {
  return function() {
    seed |= 0;
    seed = seed + 0x6D2B79F5 | 0;
    let t = Math.imul(seed ^ seed >>> 15, 1 | seed);
    t = t + Math.imul(t ^ t >>> 7, 61 | t);
    return ((t ^ t >>> 14) >>> 0) / 4294967296;
  };
};

const seed = stringToSeed(text);
const rng = mulberry32(seed);

const moveYMin = 5;
const moveYMax = 12;
const curveXMin = 20;
const curveXMax = 100;
const curveYMin = 5;
const curveYMax = 20;
const endYMin = 5;
const endYMax = 10;

const getRandomNumber = (min: number, max: number) => {
  return Math.floor(rng() * (max - min)) + min;
};

// Generate the unique coordinates
const moveY = getRandomNumber(moveYMin, moveYMax);
const curveX = getRandomNumber(curveXMin, curveXMax);
const curveY = getRandomNumber(curveYMin, curveYMax);
const endY = getRandomNumber(endYMin, endYMax);

const randomPathData = `M5 ${moveY} Q ${curveX} ${curveY} 170 ${endY}`;
---

<span class="relative inline-block ">
  <svg
    class="absolute left-0 -bottom-[0.6lh] w-full h-full overflow-visible z-0"
    viewBox="0 0 175 30"
  >
    <path
      d={randomPathData}
      class="stroke-green-700"
      stroke-width="8"
      fill="none"
    ></path>
  </svg>
  <span class="relative z-10">
    <slot />
  </span>
</span>
