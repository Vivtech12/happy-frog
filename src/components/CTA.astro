---
import Button from "./reusable/Button.astro";
---
<section class="bg-white w-screen">
<div class="max-w-7xl mx-auto px-4 py-16">
    <div class="max-w-5xl mx-auto text-start">
        <h2 class=" font-bold mb-6 leading-tight">
            Interested in Becoming a B2B Customer?
        </h2>
        <p class="text-lg text-gray-700 mb-8">
            We supply verified businesses across the UK with competitive prices, reliable logistics, and access to exclusive daily stock offers.
        </p>
        <p class="text-lg text-gray-700 mb-8">
            If you're a retailer, online seller, wholesaler, or chain store — we’d love to work with you.
        </p>
    </div>

    <div class="max-w-5xl mx-auto pb-16">
        <h2 class="text-2xl font-bold text-start mb-6">
            Once you're approved, you'll be able to:
        </h2>
        <ul class="space-y-4 text-lg text-gray-700 list-none mb-12">
            <li class="flex items-start">
                <svg class="flex-shrink-0 w-6 h-6 text-green-700 mr-2 mt-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>View and purchase from our full product catalog.</span>
            </li>
            <li class="flex items-start">
                <svg class="flex-shrink-0 w-6 h-6 text-green-700 mr-2 mt-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Receive a Proforma Invoice before payment.</span>
            </li>
            <li class="flex items-start">
                <svg class="flex-shrink-0 w-6 h-6 text-green-700 mr-2 mt-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Access priority stock alerts and deals.</span>
            </li>
        </ul>
        <Button link="" inverted={true} buttonText="Learn More About Us" arrow={true}/>
    </div>
</div>
</section>