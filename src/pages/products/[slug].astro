---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const electronics = await getCollection("electronics");
  return electronics.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { data } = product;
---

<Layout title={`${data.product_title} | Happy Frog`}>
  <div class="min-h-screen bg-white">
    <!-- Breadcrumb -->
    <nav class="bg-white border-b">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <ol class="flex items-center space-x-2 text-sm">
          <li>
            <a href="/" class="text-gray-600 hover:text-gray-900">Home</a>
          </li>
          <li class="text-gray-400">/</li>
          <li class="text-gray-900 truncate max-w-[70vw]">
            {data.product_title}
          </li>
        </ol>
      </div>
    </nav>

    <!-- Product Details -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Product Image -->
        <div class="space-y-4 lg:col-span-1">
          <div
            class="aspect-square flex justify-center rounded-lg overflow-hidden"
          >
            <img
              data-pagefind-meta="image[src]"
              src={data.product_image_url}
              alt={data.product_title}
              class="w-auto h-auto object-cover"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Product Info -->
        <div class="space-y-6 lg:col-span-2">
          <div>
            <h1 class="text-2xl font-semibold text-gray-900 mb-4">
              {data.product_title}
            </h1>

            <!-- Rating and Reviews -->
            <div class="flex items-center space-x-4 mb-4">
              <div class="flex items-center">
                <div class="flex items-center">
                  {
                    Array.from({ length: 5 }, (_, i) => (
                      <svg
                        class={`w-5 h-5 ${i < Math.floor(data.product_rating) ? "text-yellow-400" : "text-gray-300"}`}
                        fill="currentColor"
                        viewBox="0 0 20 20"
                      >
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))
                  }
                </div>
                <span class="ml-2 text-sm text-gray-600">
                  {data.product_rating.toFixed(1)} ({
                    data.total_reviews.toLocaleString()
                  } reviews)
                </span>
              </div>

              {
                data.is_best_seller && (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    Best Seller
                  </span>
                )
              }
            </div>

            <!-- Category -->
            <div>
              <span class="text-sm text-gray-600">Category:</span>
              <span class="ml-2 text-sm font-medium text-gray-900"
                >{data.product_category}</span
              >
            </div>

            <!-- Description -->
            <div class="mt-6">
              <h3 class="text-xl font-semibold text-gray-900 mb-3">
                Product Description
              </h3>
              <p class="text-gray-700 leading-relaxed">
                {data.product_title} is a high-quality electronic product designed
                to meet your needs. With a customer rating of {
                  data.product_rating.toFixed(1)
                }/5 stars based on {data.total_reviews.toLocaleString()} reviews,
                this product has proven to be reliable and well-regarded by customers.
                As part of our {data.product_category} collection, this item represents
                the quality and performance you expect from Happy Frog's curated
                electronics selection.
              </p>
            </div>
            <!-- Additional Info -->
            <div class="space-y-2 text-sm text-gray-600">
              {
                data.has_coupon && (
                  <div class="flex items-center">
                    <svg
                      class="w-4 h-4 mr-2 text-green-600"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"
                      />
                    </svg>
                    Coupon available
                  </div>
                )
              }

              {
                data.sustainability_tags && (
                  <div class="flex items-center mt-4">
                    <svg
                      class="w-4 h-4 mr-2 text-green-600"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                      />
                    </svg>
                    {data.sustainability_tags}
                  </div>
                )
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
